# ─────────────────────────────────────────────────────────────────────────────
# AAP Panel — Production Environment Template
#
# 1. Copy this file:   cp .env.production.example .env.production
# 2. Fill in secrets   (never commit .env.production to git)
# 3. Start:            docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Host port ─────────────────────────────────────────────────────────────────
# Port exposed on the Docker host machine (container always binds to 3777)
HOST_PORT=3777

# ── Panel URL ─────────────────────────────────────────────────────────────────
# Public-facing URL of the panel (used for CORS + internal links)
PANEL_ORIGIN=http://your-server-ip:3777

# ── Keitaro ───────────────────────────────────────────────────────────────────
KEITARO_URL=https://your-keitaro-domain.com
KEITARO_API_KEY=your_keitaro_api_key

# ── PostgreSQL (Analytics service) ───────────────────────────────────────────
ANALYTICS_DB_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_ORGS=org1,org2

# ── File paths (inside the container) ────────────────────────────────────────
# WORKSPACE_PATH on the HOST is mounted as /workspace (read-only)
# Set HOST-side path in docker-compose.yml or override WORKSPACE_PATH here
WORKSPACE_PATH=/workspace

# Path to your Claude config / workspace inside the container
# Mount the host directory in docker-compose volumes if needed
CLAUDE_PATH=/claude

# Optional: path to a sita-monitor log file
SITA_LOG_PATH=/logs/monitor.log

# ── Claude CLI (AI Analysis) ──────────────────────────────────────────────────
# Full path to the `claude` binary inside the container.
# Install claude CLI during image build or mount it as a volume.
# Leave blank to disable AI analysis on the Campaign Detail page.
CLAUDE_BIN=/usr/local/bin/claude

# ── Redis (managed by docker-compose — usually no changes needed) ─────────────
REDIS_HOST=redis
REDIS_PORT=6379
