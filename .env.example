# Jira / Confluence
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki

# Airtable
AIRTABLE_API_TOKEN=your-airtable-personal-access-token

# Keitaro
KEITARO_URL=https://your-keitaro-domain.com
KEITARO_API_KEY=your-keitaro-api-key

# GitHub
GITHUB_TOKEN=ghp_your_github_token
GITHUB_ORGS=org1,org2

# Access Control (optional — leave empty for no auth)
MCC_ACCESS_PASSWORD=

# Local paths (for dev only)
WORKSPACE_PATH=/path/to/workspace
CLAUDE_PATH=/path/to/claude/config
